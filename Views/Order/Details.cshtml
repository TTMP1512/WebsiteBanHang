@model WebsiteBanHang.Models.Order
@{
    ViewData["Title"] = "Chi Tiết Đơn Hàng";
    var details = ViewBag.OrderDetails as List<WebsiteBanHang.Models.OrderDetail>;

    // Cấu hình Timeline logic
    int step = 1;
    if (Model.OrderStatus == "Đã xác nhận") step = 2;
    if (Model.OrderStatus == "Đã gửi hàng") step = 3;
    if (Model.OrderStatus == "Đang vận chuyển") step = 4;
    if (Model.OrderStatus == "Đã giao") step = 5;
}

<div class="container mt-5 text-light">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-receipt"></i> Chi Tiết Đơn Hàng #@Model.Id</h2>
        <a asp-action="History" class="btn btn-outline-light"><i class="bi bi-arrow-left"></i> Quay lại Lịch sử</a>
    </div>

    <div class="card bg-dark border-secondary shadow-sm mb-4 p-4">
        <h4 class="text-warning mb-4">Trạng thái vận chuyển</h4>
        <div class="d-flex justify-content-between text-center position-relative">
            <div class="position-absolute w-100" style="height: 4px; background-color: #555; top: 15px; z-index: 1;"></div>
            <div class="position-absolute bg-success" style="height: 4px; top: 15px; z-index: 2; width: @((step - 1) * 25)% transition: width 0.5s;"></div>

            @{
                string[] statuses = { "Chờ xác nhận", "Đã xác nhận", "Đã gửi hàng", "Đang vận chuyển", "Đã giao" };
                for (int i = 0; i < statuses.Length; i++)
                {
                    bool isCompleted = (i + 1) <= step;
                    <div class="position-relative" style="z-index: 3;">
                        <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center text-white @(isCompleted ? "bg-success" : "bg-secondary")"
                             style="width: 35px; height: 35px; border: 3px solid #212529;">
                            <i class="@(isCompleted ? "bi bi-check" : "bi bi-dot") fs-4"></i>
                        </div>
                        <div class="mt-2 fw-bold @(isCompleted ? "text-success" : "text-muted")">@statuses[i]</div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card bg-dark border-secondary h-100">
                <div class="card-header bg-secondary text-white fw-bold">THÔNG TIN NHẬN HÀNG</div>
                <div class="card-body text-light">
                    <p><strong>Người nhận:</strong> @Model.Name</p>
                    <p><strong>SĐT:</strong> @Model.PhoneNumber</p>
                    <p><strong>Địa chỉ:</strong> @Model.StreetAddress, @Model.Ward, @Model.District, @Model.City</p>
                    <hr class="border-secondary" />
                    <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Hình thức:</strong> @Model.PaymentStatus</p>
                </div>
            </div>
        </div>

        <div class="col-md-8 mb-4">
            <div class="card bg-dark border-secondary h-100">
                <div class="card-header bg-secondary text-white fw-bold">SẢN PHẨM ĐÃ ĐẶT</div>
                <div class="card-body p-0">
                    <table class="table table-dark table-hover mb-0 align-middle">
                        <tbody>
                            @foreach (var item in details)
                            {
                                <tr>
                                    <td width="100">
                                        <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="img-thumbnail bg-dark border-secondary" style="height: 60px; object-fit:cover;" />
                                    </td>
                                    <td>
                                        <h6 class="mb-0 text-white">@item.Product.Name</h6>
                                        <small class="text-muted">SL: @item.Count</small>
                                    </td>
                                    <td class="text-end text-danger fw-bold">
                                        @((item.Price * item.Count).ToString("#,##0")) đ
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="border-top border-secondary">
                            <tr>
                                <td colspan="2" class="text-end fw-bold pt-3 fs-5">TỔNG CỘNG:</td>
                                <td class="text-end text-danger fw-bold pt-3 fs-5">@Model.OrderTotal.ToString("#,##0") đ</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
