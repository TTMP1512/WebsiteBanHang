@model IEnumerable<WebsiteBanHang.Models.Order>
@{
    ViewData["Title"] = "Lịch Sử Mua Hàng";
}

<div class="container mt-5">
    <h2 class="mb-4 text-primary"><i class="bi bi-clock-history"></i> Lịch Sử Mua Hàng Của Bạn</h2>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive shadow-sm">
            <table class="table table-dark table-hover table-bordered align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th>Mã Đơn</th>
                        <th>Ngày Đặt Hàng</th>
                        <th>Người Nhận</th>
                        <th>Tổng Tiền</th>
                        <th>Trạng Thái</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="fw-bold">#@order.Id</td>
                            <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@order.Name</td>
                            <td class="text-danger fw-bold">@order.OrderTotal.ToString("#,##0") VNĐ</td>
                            <td>
                                @if (order.OrderStatus == "Chờ xác nhận")
                                {
                                    <span class="badge bg-warning text-dark px-3 py-2">@order.OrderStatus</span>
                                }
                                else if (order.OrderStatus == "Đã giao")
                                {
                                    <span class="badge bg-success px-3 py-2">@order.OrderStatus</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark px-3 py-2">@order.OrderStatus</span>
                                }
                            </td>
                            <td>
                                <a asp-controller="Order" asp-action="Details" asp-route-id="@order.Id" class="btn btn-outline-info btn-sm">
                                    <i class="bi bi-eye"></i> Xem Chi Tiết
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center p-5">
            <h4>Bạn chưa có đơn hàng nào!</h4>
            <p>Hãy dạo quanh cửa hàng và chọn cho mình những món đồ yêu thích nhé.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">Khám phá ngay</a>
        </div>
    }
</div>