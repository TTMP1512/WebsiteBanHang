@model IEnumerable<WebsiteBanHang.Models.Order>
@{
    ViewData["Title"] = "Quản Lý Đơn Hàng (Admin)";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-warning"><i class="bi bi-kanban"></i> Quản Lý Đơn Hàng Của Khách</h2>
    </div>

    <div class="table-responsive bg-dark p-3 rounded shadow-sm border border-secondary">
        <table class="table table-dark table-hover align-middle text-center mb-0">
            <thead class="table-active">
                <tr>
                    <th>Mã Đơn</th>
                    <th>Ngày Đặt</th>
                    <th>Khách Hàng</th>
                    <th>Tổng Tiền</th>
                    <th>Trạng Thái Hiện Tại</th>
                    <th>Cập Nhật Trạng Thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">#@item.Id</td>
                        <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-start">
                            <strong>@item.Name</strong><br />
                            <small class="text-muted"><i class="bi bi-telephone"></i> @item.PhoneNumber</small>
                        </td>
                        <td class="text-danger fw-bold">@item.OrderTotal.ToString("#,##0") đ</td>
                        <td>
                            @if (item.OrderStatus == "Đã giao")
                            {
                                <span class="badge bg-success">@item.OrderStatus</span>
                            }
                            else if (item.OrderStatus == "Chờ xác nhận")
                            {
                                <span class="badge bg-warning text-dark">@item.OrderStatus</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark">@item.OrderStatus</span>
                            }
                        </td>
                        <td style="width: 250px;">
                            <form asp-action="UpdateStatus" method="post" class="d-flex">
                                <input type="hidden" name="id" value="@item.Id" />
                                <select name="status" class="form-select form-select-sm me-2 bg-secondary text-light border-0">
                                    <option value="Chờ xác nhận" selected="@(item.OrderStatus == "Chờ xác nhận")">Chờ xác nhận</option>
                                    <option value="Đã xác nhận" selected="@(item.OrderStatus == "Đã xác nhận")">Đã xác nhận</option>
                                    <option value="Đã gửi hàng" selected="@(item.OrderStatus == "Đã gửi hàng")">Đã gửi hàng</option>
                                    <option value="Đang vận chuyển" selected="@(item.OrderStatus == "Đang vận chuyển")">Đang vận chuyển</option>
                                    <option value="Đã giao" selected="@(item.OrderStatus == "Đã giao")">Đã giao</option>
                                </select>
                                <button type="submit" class="btn btn-success btn-sm"><i class="bi bi-check-circle"></i> Lưu</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>