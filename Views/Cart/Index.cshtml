@model List<WebsiteBanHang.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    decimal grandTotal = Model.Sum(x => x.Total);
}

<div class="container mt-5">
    <h2 class="mb-4 text-success"><i class="bi bi-cart3"></i> Giỏ Hàng Của Bạn</h2>

    @if (Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr class="text-center">
                        <th>Hình ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Đơn giá</th>
                        <th>Số lượng</th>
                        <th>Thành tiền</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="text-center">
                            <td>
                                <img src="@item.ImageUrl" alt="@item.ProductName" style="width: 80px; height: 80px; object-fit: cover;" class="rounded" />
                            </td>
                            <td class="text-start fw-bold">@item.ProductName</td>
                            <td class="text-danger fw-bold">@item.Price.ToString("#,##0") VNĐ</td>
                            <td>
                                <div class="d-flex justify-content-center align-items-center">
                                    <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.ProductId" asp-route-quantity="-1" class="btn btn-outline-secondary btn-sm me-2 fw-bold">-</a>
                                    <span class="fs-5">@item.Quantity</span>
                                    <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.ProductId" asp-route-quantity="1" class="btn btn-outline-secondary btn-sm ms-2 fw-bold">+</a>
                                </div>
                            </td>
                            <td class="text-danger fw-bold">@item.Total.ToString("#,##0") VNĐ</td>
                            <td>
                                <a asp-controller="Cart" asp-action="RemoveCart" asp-route-id="@item.ProductId" class="btn btn-danger btn-sm">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row mt-4">
            <div class="col-md-6 offset-md-6 text-end">
                <h4 class="text-uppercase">Tổng thanh toán: <span class="text-danger fw-bold fs-3">@grandTotal.ToString("#,##0") VNĐ</span></h4>
                <div class="mt-3">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-lg"><i class="bi bi-arrow-left"></i> Tiếp tục mua sắm</a>
                    <a asp-controller="Checkout" asp-action="Index" class="btn btn-success btn-lg ms-2">Thanh toán ngay <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center p-5" role="alert">
            <h4 class="alert-heading">Giỏ hàng trống!</h4>
            <p>Bạn chưa thêm bất kỳ sản phẩm nào vào giỏ hàng.</p>
            <hr>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">Quay lại cửa hàng</a>
        </div>
    }
</div>
