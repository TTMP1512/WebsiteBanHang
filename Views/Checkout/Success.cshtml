@{
    ViewData["Title"] = "Đặt Hàng Thành Công";
}

<div class="container mt-5 text-center">
    <div class="card shadow border-0 mx-auto" style="max-width: 600px;">
        <div class="card-body p-5">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
            <h1 class="mt-4 text-success fw-bold">ĐẶT HÀNG THÀNH CÔNG!</h1>
            <p class="lead mt-3 text-muted">Cảm ơn bạn đã tin tưởng và mua sắm tại cửa hàng của chúng tôi.</p>
            <p>Hệ thống đã ghi nhận đơn hàng và sẽ liên hệ với bạn trong thời gian sớm nhất để xác nhận giao hàng.</p>

            <hr class="my-4">

            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg mt-2">Tiếp Tục Mua Sắm</a>
        </div>
    </div>
