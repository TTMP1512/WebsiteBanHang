@model IEnumerable<WebsiteBanHang.Models.ApplicationUser>
@{
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="container mt-5">
    <h2 class="text-warning"><i class="bi bi-people"></i> Quản lý Người Dùng</h2>
    <table class="table table-dark table-hover mt-3 align-middle">
        <thead class="table-active">
            <tr>
                <th>Email</th>
                <th>Họ Tên</th>
                <th>SĐT</th>
                <th>Trạng Thái</th>
                <th>Hành Động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                // Kiểm tra xem tài khoản có đang bị khóa hay không
                bool isLocked = user.LockoutEnd != null && user.LockoutEnd > DateTimeOffset.UtcNow;
                <tr>
                    <td>@user.Email</td>
                    <td class="fw-bold">@user.FullName</td>
                    <td>@user.PhoneNumber</td>
                    <td>
                        @if (isLocked)
                        {
                            <span class="badge bg-danger px-3 py-2">Bị Khóa</span>
                        }
                        else
                        {
                            <span class="badge bg-success px-3 py-2">Hoạt động</span>
                        }
                    </td>
                    <td>
                        <form asp-action="ToggleLock" asp-route-id="@user.Id" method="post">
                            @if (isLocked)
                            {
                                <button class="btn btn-sm btn-success"><i class="bi bi-unlock"></i> Mở Khóa</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-danger"><i class="bi bi-lock"></i> Khóa TK</button>
                            }
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>