@model IEnumerable<WebsiteBanHang.Models.Product>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-white fw-bold m-0">Danh Sách Sản Phẩm</h2>
    <a asp-action="Add" class="btn btn-primary fw-bold">+ Thêm Sản Phẩm Mới</a>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var product in Model)
    {
        <div class="col">
            <div class="card h-100 bg-dark border-secondary shadow-sm">

                @if (!string.IsNullOrEmpty(product.ImageUrl))
                {
                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height: 250px; object-fit: cover;">
                }
                else
                {
                    <img src="https://via.placeholder.com/300x250?text=No+Image" class="card-img-top" alt="No Image" style="height: 250px; object-fit: cover;">
                }

                <div class="card-body d-flex flex-column text-light">
                    <h5 class="card-title text-success fw-bold text-truncate" title="@product.Name">@product.Name</h5>

                    <h4 class="card-text text-warning fw-bold mb-3">@product.Price.ToString("#,##0.00") $</h4>

                    <p class="card-text mb-1"><span class="badge bg-secondary">@product.Category?.Name</span></p>
                    <p class="card-text text-muted flex-grow-1" style="font-size: 0.9rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                        @product.Description
                    </p>
                </div>

                <div class="card-footer bg-transparent border-top border-secondary text-center pt-3 pb-3">
                    <a asp-action="Display" asp-route-id="@product.Id" class="btn btn-info btn-sm text-white me-2 px-3">View</a>
                    <a asp-action="Update" asp-route-id="@product.Id" class="btn btn-warning btn-sm text-dark me-2 px-3">Edit</a>
                    <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-danger btn-sm text-white px-3">Delete</a>
                </div>
            </div>
        </div>
    }
</div>